APP_NAME="SmartBudget API"
APP_ENV=dev
APP_VERSION=0.1.0
APP_HOST=127.0.0.1
APP_PORT=8000

BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Database (example only — do NOT use real credentials here)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5433/db_name

# Security
SECRET_KEY=your-secret-key-here

POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

UPLOAD_DIR=uploads